{
  "name": "stealth-chat",
  "version": "1.0.0",
  "description": "Stealth AI chat assistant (invisible to screen sharing)",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
