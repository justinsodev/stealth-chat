{
  "name": "stealth-chat",
  "version": "1.0.0",
  "description": "Stealth AI chat assistant (invisible to screen sharing)",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac"
  },
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "koffi": "^3.1.1",
    "openai": "^4.77.0"
  },
  "build": {
    "appId": "com.stealth.chat",
    "productName": "Stealth Chat",
    "asar": false,
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "dmg": {
      "title": "Stealth Chat"
    }
  }
}
